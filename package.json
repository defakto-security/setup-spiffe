{
  "name": "setup-spiffe",
  "version": "0.1.0",
  "private": true,
  "description": "GitHub Action that mints a SPIFFE SVID for a workflow job by attesting its GitHub OIDC token to a Defakto endpoint.",
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/main.ts -o dist --license licenses.txt",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write src",
    "all": "npm run typecheck && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/defakto-security/setup-spiffe.git"
  },
  "license": "Apache-2.0",
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@defakto/spiffe": "^0.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vercel/ncc": "^0.38.3",
    "prettier": "^3.0.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20"
  }
}
